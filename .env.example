# Copy this file to `.env` and fill in. `.env` is git-ignored.
# Used by docker-compose.mem0.yml.

# --- mem0 server ---
# Bearer key the BuilderQuest Admin Console will paste in. Generate any
# random secret (e.g. `openssl rand -hex 32`).
MEM0_API_KEY=replace-me-with-a-long-random-secret
# Port the mem0 HTTP API binds to.
MEM0_PORT=8000

# --- Postgres + pgvector (the only data store mem0 needs) ---
POSTGRES_DB=mem0
POSTGRES_USER=mem0
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# --- LLM provider for mem0 fact extraction ---
# Pick "openai" or "anthropic". Mem0 will use whichever key matches.
MEM0_LLM_PROVIDER=openai
# At least one of these must be set:
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Embeddings provider (default: openai). Leave alone unless you have a
# reason.
MEM0_EMBEDDING_PROVIDER=openai
