# Copy this file to `.env` and fill in. `.env` is git-ignored.
# Used by docker-compose.mem0.yml.

# --- mem0 server ---
# Image to pull. Defaults to oznakash's fork on GHCR. Pin to a SHA tag
# (e.g. ghcr.io/oznakash/mem0:sha-abc1234) for deterministic prod deploys.
MEM0_IMAGE=ghcr.io/oznakash/mem0:latest
# Bearer key the BuilderQuest Admin Console will paste in. Generate any
# random secret (e.g. `openssl rand -hex 32`).
MEM0_API_KEY=replace-me-with-a-long-random-secret
# Port the mem0 HTTP API binds to.
MEM0_PORT=8000

# --- Postgres + pgvector (the only data store mem0 needs) ---
POSTGRES_DB=mem0
POSTGRES_USER=mem0
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# --- LLM provider for mem0 fact extraction ---
# Pick "openai" or "anthropic". Mem0 will use whichever key matches.
MEM0_LLM_PROVIDER=openai
# At least one of these must be set:
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Embeddings provider (default: openai). Leave alone unless you have a
# reason.
MEM0_EMBEDDING_PROVIDER=openai

# --- LinkedIn Connect (social-svc) ---
# Powers "Connect with LinkedIn" on the profile editor. When
# LINKEDIN_CLIENT_ID is empty the integration is disabled and the SPA
# falls back to intent capture. Full strategy: docs/profile-linkedin.md.
#
# Operator setup (SPA needs no rebuild to flip on):
#   1. Create a LinkedIn Developer App at https://www.linkedin.com/developers/apps
#   2. Auth tab → add redirect URL:
#      https://learnai.cloud-claude.com/v1/social/me/linkedin/callback
#   3. Products tab → request "Sign In with LinkedIn using OpenID Connect"
#   4. Drop the credentials onto social-svc via the Cloud-Claude MCP
#   5. Redeploy social-svc
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://learnai.cloud-claude.com/v1/social/me/linkedin/callback
# Origin of the SPA. Used to redirect back to /network after the OAuth
# callback (?linkedin=connected). Same-origin deploys can leave empty.
SOCIAL_APP_ORIGIN=https://learnai.cloud-claude.com
